# ==============================================================================
#  yabai / skhd hotkeys  --  obscured "WM control panel" namespace
#
#  Every chord below is emitted by the smcboard40 ZMK layers, not typed by hand:
#    WM  page 1 = hold LH2          WM2 page 2 = hold LH2 + RH0      APP = hold LB4
#  Two collision-safe modifier planes (neither is used by macOS or apps):
#    HYPER = cmd + ctrl + shift + alt  ->  navigate (focus / spaces / cycle / float / apps)
#    MEH   = ctrl + shift + alt        ->  manipulate (move / resize / stacks / insert / ...)
#  Keep in sync with ~/dev/zmk-config/config/smcboard40.keymap.
# ==============================================================================

# ------------------------------------------------------------------------------
#  HYPER  --  navigate
# ------------------------------------------------------------------------------

# Focus window (hjkl), crossing display borders
cmd + ctrl + shift + alt - h : yabai -m window --focus west  || yabai -m display --focus west
cmd + ctrl + shift + alt - j : yabai -m window --focus south || yabai -m display --focus south
cmd + ctrl + shift + alt - k : yabai -m window --focus north || yabai -m display --focus north
cmd + ctrl + shift + alt - l : yabai -m window --focus east  || yabai -m display --focus east

# Cycle windows in current space: p = prev, n = next
cmd + ctrl + shift + alt - p : yabai -m query --spaces --space \
  | jq -re ".index" \
  | xargs -I{} yabai -m query --windows --space {} \
  | jq -r '[.[] | select(.["is-minimized"]? != true)] | sort_by(.display, .frame.y, .frame.x, .id) | reverse | nth(index(map(select(.["has-focus"]? == true))) - 1).id' \
  | xargs -I{} yabai -m window --focus {}
cmd + ctrl + shift + alt - n : yabai -m query --spaces --space \
  | jq -re ".index" \
  | xargs -I{} yabai -m query --windows --space {} \
  | jq -r '[.[] | select(.["is-minimized"]? != true)] | sort_by(.display, .frame.y, .frame.x, .id) | nth(index(map(select(.["has-focus"]? == true))) - 1).id' \
  | xargs -I{} yabai -m window --focus {}

# Focus space 1-5 on current display (0-based jq index)
cmd + ctrl + shift + alt - 1 : sh -c 'ID=$(yabai -m query --displays --display | jq -r ".spaces[0]"); [ -n "$ID" ] && [ "$ID" != null ] && yabai -m space --focus "$ID"'
cmd + ctrl + shift + alt - 2 : sh -c 'ID=$(yabai -m query --displays --display | jq -r ".spaces[1]"); [ -n "$ID" ] && [ "$ID" != null ] && yabai -m space --focus "$ID"'
cmd + ctrl + shift + alt - 3 : sh -c 'ID=$(yabai -m query --displays --display | jq -r ".spaces[2]"); [ -n "$ID" ] && [ "$ID" != null ] && yabai -m space --focus "$ID"'
cmd + ctrl + shift + alt - 4 : sh -c 'ID=$(yabai -m query --displays --display | jq -r ".spaces[3]"); [ -n "$ID" ] && [ "$ID" != null ] && yabai -m space --focus "$ID"'
cmd + ctrl + shift + alt - 5 : sh -c 'ID=$(yabai -m query --displays --display | jq -r ".spaces[4]"); [ -n "$ID" ] && [ "$ID" != null ] && yabai -m space --focus "$ID"'

# Float toggle / fullscreen / zoom-parent
cmd + ctrl + shift + alt - space : yabai -m window --toggle float
cmd + ctrl + shift + alt - f     : yabai -m window --toggle zoom-fullscreen
cmd + ctrl + shift + alt - z     : yabai -m window --toggle zoom-parent

# App focus / launcher (APP layer = hold LB4): open if closed, else cycle its windows
cmd + ctrl + shift + alt - t : ~/.config/skhd/scripts/focus-app.sh kitty
cmd + ctrl + shift + alt - b : ~/.config/skhd/scripts/focus-app.sh Safari
cmd + ctrl + shift + alt - a : ~/.config/skhd/scripts/focus-app.sh ChatGPT
cmd + ctrl + shift + alt - m : ~/.config/skhd/scripts/focus-app.sh Mail
cmd + ctrl + shift + alt - c : ~/.config/skhd/scripts/focus-app.sh Calendar

# ------------------------------------------------------------------------------
#  MEH  --  manipulate
# ------------------------------------------------------------------------------

# Move / warp window (hjkl), pushing across displays
ctrl + shift + alt - h : yabai -m window --warp west  || $(yabai -m window --display west && yabai -m display --focus west && yabai -m window --warp last) || yabai -m window --move rel:-10:0
ctrl + shift + alt - j : yabai -m window --warp south || $(yabai -m window --display south && yabai -m display --focus south) || yabai -m window --move rel:0:10
ctrl + shift + alt - k : yabai -m window --warp north || $(yabai -m window --display north && yabai -m display --focus north) || yabai -m window --move rel:0:-10
ctrl + shift + alt - l : yabai -m window --warp east  || $(yabai -m window --display east && yabai -m display --focus east && yabai -m window --warp first) || yabai -m window --move rel:10:0

# Resize (arrow keys): left/right = width, down/up = height
ctrl + shift + alt - left  : yabai -m window --resize right:-100:0 || yabai -m window --resize left:-100:0
ctrl + shift + alt - down  : yabai -m window --resize bottom:0:100 || yabai -m window --resize top:0:100
ctrl + shift + alt - up    : yabai -m window --resize bottom:0:-100 || yabai -m window --resize top:0:-100
ctrl + shift + alt - right : yabai -m window --resize right:100:0 || yabai -m window --resize left:100:0

# Move window to space 1-5
ctrl + shift + alt - 1 : sh -c 'SPACES=$(yabai -m query --displays --display | jq ".spaces[]"); set -- $SPACES; [ -n "$1" ] && yabai -m window --space "$1"'
ctrl + shift + alt - 2 : sh -c 'SPACES=$(yabai -m query --displays --display | jq ".spaces[]"); set -- $SPACES; [ -n "$2" ] && yabai -m window --space "$2"'
ctrl + shift + alt - 3 : sh -c 'SPACES=$(yabai -m query --displays --display | jq ".spaces[]"); set -- $SPACES; [ -n "$3" ] && yabai -m window --space "$3"'
ctrl + shift + alt - 4 : sh -c 'SPACES=$(yabai -m query --displays --display | jq ".spaces[]"); set -- $SPACES; [ -n "$4" ] && yabai -m window --space "$4"'
ctrl + shift + alt - 5 : sh -c 'SPACES=$(yabai -m query --displays --display | jq ".spaces[]"); set -- $SPACES; [ -n "$5" ] && yabai -m window --space "$5"'

# Move window to prev / next space (and follow it)
ctrl + shift + alt - p : yabai -m window --space prev && yabai -m space --focus prev
ctrl + shift + alt - n : yabai -m window --space next && yabai -m space --focus next

# Balance / split / gaps
ctrl + shift + alt - b : yabai -m space --balance
ctrl + shift + alt - s : yabai -m window --toggle split
ctrl + shift + alt - g : yabai -m space --toggle padding; yabai -m space --toggle gap

# Stacks: add active window onto the stack in direction (y/u/i/o = W/S/N/E)
ctrl + shift + alt - y : yabai -m window  west --stack $(yabai -m query --windows --window | jq -r '.id')
ctrl + shift + alt - u : yabai -m window south --stack $(yabai -m query --windows --window | jq -r '.id')
ctrl + shift + alt - i : yabai -m window north --stack $(yabai -m query --windows --window | jq -r '.id')
ctrl + shift + alt - o : yabai -m window  east --stack $(yabai -m query --windows --window | jq -r '.id')

# Stack focus: [ (0x21) = prev, ] (0x1E) = next
ctrl + shift + alt - 0x21 : yabai -m window --focus stack.prev
ctrl + shift + alt - 0x1E : yabai -m window --focus stack.next

# Insertion point (F13/F14/F15/F16 = W/S/N/E) + insert as stack (F17)
ctrl + shift + alt - f13 : yabai -m window --insert west
ctrl + shift + alt - f14 : yabai -m window --insert south
ctrl + shift + alt - f15 : yabai -m window --insert north
ctrl + shift + alt - f16 : yabai -m window --insert east
ctrl + shift + alt - f17 : yabai -m window --insert stack

# Mirror space: x = x-axis, v = y-axis
ctrl + shift + alt - x : yabai -m space --mirror x-axis
ctrl + shift + alt - v : yabai -m space --mirror y-axis

# New window in horizontal (, = 0x2B) / vertical (. = 0x2F) split, for any app
ctrl + shift + alt - 0x2B : yabai -m window --insert east;  skhd -k "cmd - n"
ctrl + shift + alt - 0x2F : yabai -m window --insert south; skhd -k "cmd - n"

# Restart services: F19 = yabai, F20 = skhd
ctrl + shift + alt - f19 : yabai --restart-service
ctrl + shift + alt - f20 : skhd --restart-service
